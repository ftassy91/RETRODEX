{
  "pixel_warehouse": {
    "source_name": "pixel_warehouse",
    "source_type": "catalog_seed",
    "base_url": "https://pixel.garoux.net",
    "index_url": "https://pixel.garoux.net/gameList/",
    "default_page_limit": 3,
    "enrich_details": true,
    "allowed_asset_types": []
  },
  "vgmaps": {
    "source_name": "vgmaps",
    "source_type": "external_map_index",
    "base_url": "https://www.vgmaps.com",
    "atlas_url": "https://www.vgmaps.com/Atlas/index.htm",
    "allowed_asset_types": [
      "map"
    ],
    "asset_defaults": {
      "license_status": "reference_only",
      "ui_allowed": true
    }
  },
  "vgmuseum": {
    "source_name": "vgmuseum",
    "source_type": "external_asset_archive",
    "base_url": "https://www.vgmuseum.com",
    "ui_allowed_types": [
      "manual",
      "sprite_sheet",
      "ending"
    ],
    "review_only_types": [
      "scan",
      "screenshot"
    ],
    "sections": {
      "screenshots_gb": {
        "label": "Game Boy Gamepics",
        "entry_url": "https://www.vgmuseum.com/images/gb.htm",
        "parser": "frameset_gamepics",
        "platform_raw": "Game Boy",
        "asset_type": "screenshot",
        "asset_subtype": "gamepics",
        "review_only": true
      },
      "manuals_gameboy": {
        "label": "Game Boy Scans",
        "entry_url": "https://www.vgmuseum.com/scans/gameboy.html",
        "parser": "scans_page",
        "platform_raw": "Game Boy",
        "asset_type": "manual",
        "asset_subtype": "manual"
      },
      "endings_gb": {
        "label": "Game Boy Endings",
        "entry_url": "https://www.vgmuseum.com/end/gb",
        "parser": "simple_list",
        "platform_raw": "Game Boy",
        "asset_type": "ending",
        "asset_subtype": "ending_gallery"
      },
      "rips_snes": {
        "label": "SNES Sprite Rips",
        "entry_url": "https://www.vgmuseum.com/rips/snes",
        "parser": "rips_list",
        "platform_raw": "SNES",
        "asset_type": "sprite_sheet",
        "asset_subtype": "sprite_rip",
        "exclude_title_patterns": [
          "^.+\\sseries$"
        ]
      },
      "rips_neogeo": {
        "label": "Neo-Geo Sprite Rips",
        "entry_url": "https://www.vgmuseum.com/rips/neogeo",
        "parser": "rips_list",
        "platform_raw": "Neo Geo",
        "asset_type": "sprite_sheet",
        "asset_subtype": "sprite_rip",
        "exclude_title_patterns": [
          "^neo geo system$"
        ]
      }
    },
    "asset_defaults": {
      "license_status": "reference_only",
      "ui_allowed": true
    }
  }
}
