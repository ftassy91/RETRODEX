{
  "name": "retrodexseed",
  "version": "1.0.0",
  "description": "Canonical repository root for the current RetroDex workspace.",
  "main": "verify_retrodexseed.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node backend/src/server.js",
    "dev:backend": "cd backend && node src/server.js",
    "dev:frontend": "npx serve frontend -l 3001",
    "dev": "npx concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start:backend": "cd backend && node src/server.js",
    "start:frontend": "npx http-server frontend -p 8080",
    "smoke": "cd backend && npm run smoke",
    "test": "cd backend && npm test",
    "validate:workspace": "node scripts/audit/validate_all.js",
    "inventory:local": "node scripts/data/build-local-inventory.js",
    "publish:structural:plan": "node backend/scripts/publish-structural-supabase.js",
    "publish:structural:run": "node backend/scripts/publish-structural-supabase.js --apply",
    "publish:media:plan": "node backend/scripts/publish-media-references-supabase.js",
    "publish:media:run": "node backend/scripts/publish-media-references-supabase.js --apply",
    "publish:records:plan": "node backend/scripts/publish-records-supabase.js",
    "publish:records:run": "node backend/scripts/publish-records-supabase.js --apply",
    "publish:editorial:plan": "node backend/scripts/publish-editorial-supabase.js",
    "publish:editorial:run": "node backend/scripts/publish-editorial-supabase.js --apply",
    "publish:credits-music:plan": "node backend/scripts/publish-credits-music-supabase.js",
    "publish:credits-music:run": "node backend/scripts/publish-credits-music-supabase.js --apply",
    "publish:external-assets:plan": "node backend/scripts/publish-external-assets-supabase.js",
    "publish:external-assets:run": "node backend/scripts/publish-external-assets-supabase.js --apply",
    "curation:pass1:plan": "node backend/scripts/run-pass1-curation.js",
    "curation:pass1:run": "node backend/scripts/run-pass1-curation.js --apply",
    "publish:curation:plan": "node backend/scripts/publish-curation-supabase.js",
    "publish:curation:run": "node backend/scripts/publish-curation-supabase.js --apply",
    "publish:plan": "node backend/scripts/publish-sandbox-to-supabase.js --dry-run",
    "publish:run": "node backend/scripts/publish-sandbox-to-supabase.js --write"
  },
