PORT=3000
SQLITE_STORAGE=./storage/retrodex.sqlite

# PostgreSQL is optional.
# If DATABASE_URL or PG* variables are set, the backend will use PostgreSQL.
# Otherwise it keeps the beginner-friendly SQLite default.
DATABASE_URL=
PGHOST=
PGPORT=5432
PGDATABASE=retrodex
PGSCHEMA=
PGFALLBACKDATABASE=
PGUSER=
PGPASSWORD=
PGSSLMODE=disable
