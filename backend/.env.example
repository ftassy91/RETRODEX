PORT=3000
NODE_ENV=development

# Database Configuration
# Local dev uses SQLite (backend/storage/retrodex.sqlite) — no env var needed
# To use PostgreSQL instead: set DATABASE_URL below
# To use Supabase (Vercel prod): set SUPABASE_URL, SUPABASE_SERVICE_KEY, SUPABASE_ANON_KEY
# NOTE: SQLite and Supabase are independent — local data does NOT sync with production
DATABASE_URL=postgresql://user:password@host:5432/railway

# API key for protected admin/sync routes (x-api-key header)
RETRODEX_API_KEY=

ANTHROPIC_API_KEY=sk-ant-...
NOTION_TOKEN=secret_...
NOTION_SCREENSHOT_DIR=data/screenshots
NOTION_MAX_SCREENSHOTS=15
