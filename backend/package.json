{
  "name": "retrodex-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal Express + Sequelize backend for RetroDex.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest",
    "sync": "node src/sync.js",
    "smoke": "node src/smoke-test.js",
    "db:migrate": "node scripts/db-migrate.js",
    "db:check-runtime": "node scripts/db-check-runtime.js",
    "db:bootstrap-local": "node scripts/db-bootstrap-local.js",
    "db:seed-prototype-local": "node scripts/db-seed-prototype-local.js",
    "check:runtime": "npm run db:check-runtime && npm run check:runtime-boundaries && npm run verify:runtime-nonmutating",
    "check:runtime-boundaries": "node scripts/check-runtime-boundaries.js",
    "verify:runtime-nonmutating": "node scripts/verify-runtime-nonmutating.js",
    "publish:competitive:plan": "node scripts/publish-competitive-supabase.js",
    "publish:competitive:run": "node scripts/publish-competitive-supabase.js --apply",
    "enrichment:freeze-top1000": "node scripts/enrichment/generate-top-1000-work-catalog.js",
    "enrichment:freeze-extension200": "node scripts/enrichment/generate-extension-200-work-catalog.js",
    "enrichment:freeze-top1200-band": "node scripts/enrichment/generate-top1200-selection-band.js",
    "enrichment:report-top1200": "node scripts/enrichment/report-top1200-progress.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node"
  }
}
