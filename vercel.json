{
  "version": 2,
  "builds": [
    { "src": "backend/src/server.js", "use": "@vercel/node" },
    { "src": "backend/public/**", "use": "@vercel/static" }
  ],
  "installCommand": "npm install && cd backend && npm install",
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/src/server.js" },
    { "src": "/", "dest": "backend/public/hub.html" },
    { "src": "/(.*)", "dest": "backend/public/$1" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400"}]
    },
    {
      "source": "/hub.html",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400"}]
    },
    {
      "source": "/js/(.*)",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400"}]
    },
    {
      "source": "/style.css",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400"}]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=604800, s-maxage=604800"}]
    },
    {
      "source": "/api/stats",
      "headers": [{"key": "Cache-Control", "value": "public, s-maxage=300, stale-while-revalidate=3600"}]
    },
    {
      "source": "/api/games",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=30"}]
    },
    {
      "source": "/api/games/(.*)",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=60, s-maxage=300, stale-while-revalidate=60"}]
    },
    {
      "source": "/api/consoles(.*)",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=300, s-maxage=600"}]
    },
    {
      "source": "/api/collection/(.*)",
      "headers": [{"key": "Cache-Control", "value": "private, no-store"}]
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "regions": ["cdg1"]
}
